# LaTeX build artifacts — keep only .tex and figs/; the .pdf is a build
# product (regenerate with tools/latex_compile.py)
*.aux
*.log
*.out
*.synctex.gz
*.toc
*.lof
*.lot
*.fls
*.fdb_latexmk
*.bbl
*.blg
*.nav
*.snm
*.vrb
/latex/*.pdf
/latex/docs/*.pdf

# Python
__pycache__/
*.pyc

# Julia
/docs/build/
*.jl.cov
*.jl.mem

# Analysis outputs: the result files under out/ (toml, png) ARE committed; the
# .npz volume caches (recon/dose-sweep) are regenerable and stay untracked via
# the global *.npz rule below — so out/ is tracked except its heavy caches.
*.npz
# The frozen cross-validation reference is committed (see test/make_reference.py)
!/test/data/endpoint_reference.npz
# Detector sensitivity maps under out/: ~1e9-sample, expensive to rebuild — kept.
!/out/**/sensitivity/*.npz

# Reference papers (copyrighted; kept locally, not committed)
/papers/

# OS
.DS_Store
